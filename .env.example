# Backend (read by api container — keep secrets only on server)

# Отправка кода на почту: ваш PHP-скрипт (PHPMailer и т.д.).
# URL полного эндпоинта, как в браузере/curl, например: https://ваш-сайт.ru/api/send-code.php
# Если не указать — по умолчанию используется старый хост vpnm.ru (нужен только совместимый токен).
SEND_CODE_API_URL=
# Тот же секрет, что в PHP в $validApiToken: заголовок Authorization: Bearer <значение>
SEND_CODE_API_TOKEN=

# Отправитель письма с кодом (должен быть верифицирован в AWS SES того же региона, что и PHP-мейлер).
# Меняйте здесь при смене домена отправки — пересборка фронта не нужна, достаточно:
#   docker compose up -d --force-recreate api
SEND_CODE_SENDER_NAME=220v
SEND_CODE_SENDER_EMAIL=support@220v.shop

REMNAWAVE_URL=https://remna.2oo.uk
REMNAWAVE_TOKEN=
MAX_DEVICES=7

# RMW — сессия/пользователь после входа (POST /v1/auth/session) и оплата (POST /v1/billing/checkout)
RMW_API_URL=
RMW_API_KEY=

# Текст важного объявления на /support (приоритетнее GET {RMW_API_URL}/announcement; если задан — запрос к RMW не делается)
# NOTICE=

# Редиректы после оплаты (абсолютные https URL) для тела checkout
# Либо задайте оба URL:
# BILLING_SUCCESS_URL=https://220v.shop/pay/success
# BILLING_CANCEL_URL=https://220v.shop/pay/fail
# Либо один origin — тогда используются {PUBLIC_SITE_URL}/pay/success и /pay/fail
PUBLIC_SITE_URL=https://220v.shop

# Optional: API port inside container (default 3001)
# PORT=3001

# Local Vite dev: optional override (default /api — proxied to localhost:3001)
# VITE_API_URL=/api

# Сколько ГБ вычитать из общего лимита трафика, пришедшего из API, в личном кабинете
TRAFFIC_LIMIT_SUBTRACT_GB=0

# Talk-Me REST API (для /chat — backend-proxy к https://lcab.talk-me.ru/json/v1.0)
# Токен создаётся в ЛК Talk-Me → API → Rest API → Online-чат → Создать токен
TALKME_API_TOKEN=
